        {
          "name": "Create Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.job && data.job.id) {",
                  "  pm.collectionVariables.set('createdJobId', data.job.id);",
                  "}",
                  "pm.test('job criada', function () {",
                  "  pm.expect(data.job.id).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{businessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Atendente para sabado\",\n  \"description\": \"Atendimento ao cliente e apoio no caixa\",\n  \"category\": \"atendente\",\n  \"city\": \"Sao Jose dos Campos\",\n  \"neighborhood\": \"Centro\",\n  \"paymentAmount\": 140,\n  \"startAt\": \"2026-03-14T14:00:00.000Z\",\n  \"endAt\": \"2026-03-14T20:00:00.000Z\",\n  \"slots\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/jobs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "jobs"
              ]
            }
          }
        }
      ]
    },
