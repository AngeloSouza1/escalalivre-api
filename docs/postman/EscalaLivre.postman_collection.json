        {
          "name": "Apply To Seed Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.application && data.application.id) {",
                  "  pm.collectionVariables.set('latestApplicationId', data.application.id);",
                  "}",
                  "pm.test('application criada ou conflito tratado manualmente', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{workerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Tenho experiencia em bares e eventos\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/jobs/{{openJobId}}/applications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
